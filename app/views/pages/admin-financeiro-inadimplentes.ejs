<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inadimplentes — FitCrew Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="/images/favicon.ico">
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<section class="admin-wrapper">
    <%- include('../partials/admin-sidebar') %>
    <section class="admin-content">
        <%- include('../partials/admin-topbar') %>
        <main class="admin-main">
            <h1 class="admin-page-title">Inadimplentes</h1>
            <section class="flex gap-10 mb-16" style="margin-bottom:16px">
                <a href="/admin/financeiro" class="btn btn-outline btn-sm">Visão Geral</a>
                <a href="/admin/financeiro/receitas" class="btn btn-outline btn-sm">Receitas</a>
                <a href="/admin/financeiro/inadimplentes" class="btn btn-gold btn-sm">Inadimplentes</a>
            </section>

            <% if (lista.length === 0) { %>
            <section class="admin-card"><section class="admin-empty"><i class="fas fa-check-circle" style="color:var(--success);opacity:1"></i>Nenhum inadimplente no momento!</section></section>
            <% } else { %>
            <section class="admin-card">
                <section class="admin-card-body no-pad">
                    <section class="admin-table-wrap">
                        <table class="admin-table">
                            <thead><tr><th>Usuário</th><th>Plano</th><th>Valor</th><th>Dias em Atraso</th><th>Ação</th></tr></thead>
                            <tbody>
                            <% lista.forEach(t => { %>
                            <tr>
                                <td>
                                    <% if (t.user) { %><a href="/admin/usuarios/<%= t.user.id %>" class="fw-600"><%= t.userName %></a><% } else { %><span class="fw-600"><%= t.userName %></span><% } %>
                                    <section class="text-muted" style="font-size:.75rem"><%= t.userEmail || '' %></section>
                                </td>
                                <td><span class="badge badge-gold"><%= t.planoNome %></span></td>
                                <td class="fw-600">R$ <%= Number(t.valor).toFixed(2) %></td>
                                <td>
                                    <span class="badge <%= t.diasAtraso > 7 ? 'badge-error' : 'badge-warning' %>">
                                        <%= t.diasAtraso %> dia<%= t.diasAtraso !== 1 ? 's' : '' %>
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-outline btn-sm" onclick="alert('Notificação de cobrança enviada para <%= t.userName %>!')">
                                        <i class="fas fa-paper-plane"></i> Notificar
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                            </tbody>
                        </table>
                    </section>
                </section>
            </section>
            <% } %>
        </main>
    </section>
</section>
<script src="/js/admin.js"></script>
</body>
</html>
