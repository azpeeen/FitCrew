<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — FitCrew Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="/images/favicon.ico">
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<section class="admin-wrapper">
    <%- include('../partials/admin-sidebar') %>
    <section class="admin-content">
        <%- include('../partials/admin-topbar') %>
        <main class="admin-main">
            <h1 class="admin-page-title">Dashboard</h1>
            <p class="admin-page-subtitle">Visão geral em tempo real do FitCrew</p>

            <!-- KPIs -->
            <section class="admin-kpi-grid">
                <section class="admin-kpi">
                    <section class="admin-kpi-icon"><i class="fas fa-users"></i></section>
                    <section>
                        <section class="admin-kpi-label">Total de Usuários</section>
                        <section class="admin-kpi-value" id="kpi-usuarios"><%= totalUsuarios %></section>
                        <section class="admin-kpi-sub">cadastrados na plataforma</section>
                    </section>
                </section>
                <section class="admin-kpi">
                    <section class="admin-kpi-icon success"><i class="fas fa-running"></i></section>
                    <section>
                        <section class="admin-kpi-label">Check-ins Hoje</section>
                        <section class="admin-kpi-value" id="kpi-checkins"><%= ativosHoje %></section>
                        <section class="admin-kpi-sub">entradas registradas</section>
                    </section>
                </section>
                <section class="admin-kpi">
                    <section class="admin-kpi-icon"><i class="fas fa-dollar-sign"></i></section>
                    <section>
                        <section class="admin-kpi-label">Receita do Mês</section>
                        <section class="admin-kpi-value" id="kpi-receita">R$ <%= receitaMes %></section>
                        <section class="admin-kpi-sub">transações pagas</section>
                    </section>
                </section>
                <section class="admin-kpi">
                    <section class="admin-kpi-icon error"><i class="fas fa-headset"></i></section>
                    <section>
                        <section class="admin-kpi-label">Tickets Abertos</section>
                        <section class="admin-kpi-value" id="kpi-tickets"><%= ticketsAbertosN %></section>
                        <section class="admin-kpi-sub">chamados pendentes</section>
                    </section>
                </section>
            </section>

            <!-- Usuários online agora + Últimos cadastros -->
            <section class="admin-2col" style="margin-bottom:24px">
                <!-- Online agora -->
                <section class="admin-card">
                    <section class="admin-card-header">
                        <span class="admin-card-title">
                            <span class="online-dot" style="display:inline-block;margin-right:6px"></span>
                            Online Agora
                        </span>
                        <span class="badge badge-success" id="online-count-badge">0</span>
                    </section>
                    <section class="admin-card-body no-pad" id="online-list" style="max-height:280px;overflow-y:auto">
                        <section class="admin-empty" style="padding:32px 20px">
                            <i class="fas fa-satellite-dish" style="font-size:1.8rem;opacity:.2;display:block;margin-bottom:8px"></i>
                            Aguardando atividade...
                        </section>
                    </section>
                </section>

                <!-- Últimos cadastros -->
                <section class="admin-card">
                    <section class="admin-card-header">
                        <span class="admin-card-title">Últimos Cadastros</span>
                        <a href="/admin/usuarios" class="btn btn-outline btn-sm">Ver todos</a>
                    </section>
                    <section class="admin-card-body no-pad">
                        <table class="admin-table" id="recent-users-table">
                            <thead><tr><th>Nome</th><th>Plano</th><th>Cadastro</th></tr></thead>
                            <tbody id="recent-users-body">
                            <% ultimosCadastros.forEach(u => { %>
                            <tr>
                                <td><a href="/admin/usuarios/<%= u.id %>"><%= u.nome %></a></td>
                                <td><span class="badge badge-gold"><%= u.plano || '—' %></span></td>
                                <td class="text-muted"><%= u.created_at.toLocaleDateString('pt-BR') %></td>
                            </tr>
                            <% }) %>
                            </tbody>
                        </table>
                    </section>
                </section>
            </section>

            <!-- Gráficos -->
            <section class="admin-charts-grid">
                <section class="admin-card">
                    <section class="admin-card-header">
                        <span class="admin-card-title"><i class="fas fa-chart-line text-gold"></i> Novos Cadastros — Últimos 30 dias</span>
                    </section>
                    <section class="admin-card-body">
                        <section class="chart-wrap"><canvas id="chartCadastros"></canvas></section>
                    </section>
                </section>
                <section class="admin-card">
                    <section class="admin-card-header">
                        <span class="admin-card-title"><i class="fas fa-chart-bar text-gold"></i> Check-ins por Dia</span>
                    </section>
                    <section class="admin-card-body">
                        <section class="chart-wrap"><canvas id="chartCheckins"></canvas></section>
                    </section>
                </section>
            </section>

            <!-- Tickets urgentes -->
            <section class="admin-card" style="margin-top:24px">
                <section class="admin-card-header">
                    <span class="admin-card-title"><i class="fas fa-exclamation-triangle text-warning"></i> Tickets Urgentes</span>
                    <a href="/admin/suporte" class="btn btn-outline btn-sm">Ver todos</a>
                </section>
                <section class="admin-card-body no-pad">
                    <% if (ticketsUrgentes.length === 0) { %>
                    <section class="admin-empty" style="padding:24px"><i class="fas fa-check-circle" style="opacity:.5;color:var(--success);font-size:1.5rem;display:block;margin-bottom:8px"></i>Nenhum ticket urgente</section>
                    <% } else { %>
                    <table class="admin-table">
                        <thead><tr><th>Usuário</th><th>Assunto</th><th>Há</th></tr></thead>
                        <tbody>
                        <% ticketsUrgentes.forEach(t => { const horas = Math.floor((Date.now() - new Date(t.created_at)) / 3600000); %>
                        <tr>
                            <td><%= t.userName %></td>
                            <td><a href="/admin/suporte/<%= t.id %>"><%= t.assunto.substring(0,40) %></a></td>
                            <td class="text-error"><%= horas %>h</td>
                        </tr>
                        <% }) %>
                        </tbody>
                    </table>
                    <% } %>
                </section>
            </section>
        </main>
    </section>
</section>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="/js/admin.js"></script>
<script>
const chartDefaults = { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { grid: { color: '#2A2A2A' }, ticks: { color: '#9A9A9A', font: { size: 10 }, maxTicksLimit: 10 } }, y: { grid: { color: '#2A2A2A' }, ticks: { color: '#9A9A9A' }, beginAtZero: true } } };

Chart.getChart(document.getElementById('chartCadastros'))?.destroy();
new Chart(document.getElementById('chartCadastros'), {
    type: 'line',
    data: {
        labels: <%- labelsDias %>,
        datasets: [{ label: 'Cadastros', data: <%- cadastrosPorDia %>, borderColor: '#C98B1D', backgroundColor: 'rgba(201,139,29,0.1)', tension: 0.4, fill: true, pointRadius: 3 }]
    },
    options: chartDefaults
});

Chart.getChart(document.getElementById('chartCheckins'))?.destroy();
new Chart(document.getElementById('chartCheckins'), {
    type: 'bar',
    data: {
        labels: <%- diasSemana %>,
        datasets: [{ label: 'Check-ins', data: <%- checkinsPorDiaSemana %>, backgroundColor: 'rgba(201,139,29,0.7)', borderRadius: 5 }]
    },
    options: chartDefaults
});

// ── SSE: online users + novos usuários ───────────────────────────────────────
if (window._adminSSE) {
    window._adminSSE.addEventListener('online_users', function(e) {
        updateOnlineList(JSON.parse(e.data));
    });
    window._adminSSE.addEventListener('user_online', function(e) {
        const u = JSON.parse(e.data);
        addOnlineUser(u);
        addRecentUser(u);
        // Atualiza KPI
        const kpi = document.getElementById('kpi-usuarios');
        if (kpi) kpi.textContent = parseInt(kpi.textContent) + 1;
    });
    window._adminSSE.addEventListener('user_activity', function(e) {
        const u = JSON.parse(e.data);
        updateUserActivity(u);
    });
    window._adminSSE.addEventListener('new_ticket', function(e) {
        const t = JSON.parse(e.data);
        const kpi = document.getElementById('kpi-tickets');
        if (kpi) kpi.textContent = parseInt(kpi.textContent) + 1;
    });
}

function updateOnlineList(users) {
    const el = document.getElementById('online-list');
    const badge = document.getElementById('online-count-badge');
    if (badge) badge.textContent = users.length;
    if (!el) return;
    if (!users.length) {
        el.innerHTML = '<section class="admin-empty" style="padding:32px 20px"><i class="fas fa-satellite-dish" style="font-size:1.8rem;opacity:.2;display:block;margin-bottom:8px"></i>Aguardando atividade...</section>';
        return;
    }
    el.innerHTML = users.map(u => `
        <section class="online-user-row">
            <section class="online-user-avatar">${u.nome.charAt(0).toUpperCase()}</section>
            <section class="online-user-info">
                <section class="fw-600" style="font-size:.82rem">${escHtml(u.nome)}</section>
                <section class="text-muted" style="font-size:.7rem">${escHtml(u.page)}</section>
            </section>
            <span class="online-dot"></span>
        </section>`).join('');
}

function addOnlineUser(u) {
    const el = document.getElementById('online-list');
    const badge = document.getElementById('online-count-badge');
    if (!el) return;
    // Remove empty state
    const empty = el.querySelector('.admin-empty');
    if (empty) empty.remove();
    if (badge) badge.textContent = parseInt(badge.textContent || '0') + 1;
    // userRow: self-contained online-user entry (avatar + name + current page)
    const userRow = document.createElement('section');
    userRow.className = 'online-user-row online-user-new';
    userRow.dataset.uid = u.id;
    userRow.innerHTML = `<section class="online-user-avatar">${u.nome.charAt(0).toUpperCase()}</section><section class="online-user-info"><section class="fw-600" style="font-size:.82rem">${escHtml(u.nome)}</section><section class="text-muted" style="font-size:.7rem">${escHtml(u.page)}</section></section><span class="online-dot"></span>`;
    el.prepend(userRow);
    setTimeout(() => userRow.classList.remove('online-user-new'), 600);
}

function updateUserActivity(u) {
    const row = document.querySelector(`[data-uid="${u.id}"]`);
    if (row) {
        const pageEl = row.querySelector('.text-muted');
        if (pageEl) pageEl.textContent = u.page;
    }
}

function addRecentUser(u) {
    const tbody = document.getElementById('recent-users-body');
    if (!tbody) return;
    const tr = document.createElement('tr');
    tr.className = 'new-row-animate';
    tr.innerHTML = `<td><a href="/admin/usuarios/${u.id}">${escHtml(u.nome)}</a></td><td><span class="badge badge-gold">—</span></td><td class="text-muted">agora</td>`;
    tbody.prepend(tr);
    if (tbody.children.length > 6) tbody.lastElementChild.remove();
}

function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
</body>
</html>
